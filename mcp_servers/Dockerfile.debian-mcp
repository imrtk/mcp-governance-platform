FROM python:3.11-slim

RUN apt-get update && apt-get install -y openssh-client && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir mcp fastapi uvicorn pyyaml

WORKDIR /app

RUN mkdir -p /app/mcp_servers /app/config

COPY mcp_servers/debian_mcp.py /app/mcp_servers/debian_mcp.py

ENV MCP_PORT=8003

EXPOSE 8003

CMD ["uvicorn", "mcp_servers.debian_mcp:app", "--host", "0.0.0.0", "--port", "8003"]
