# vCenter — zorunlu (VM yönetimi için)
VCENTER_HOST="vcenter.example.com"
VCENTER_USER="administrator@vsphere.local"
VCENTER_PASSWORD="your-password"
VCENTER_PORT="443"
VCENTER_DATACENTER="Datacenter"
VCENTER_SSL_VERIFY="false"

# DigitalOcean — opsiyonel (sadece DO kullanıyorsanız)
# DO_API_TOKEN="dop_v1_..."
# DO_PROJECT_ID="..."

# Gateway — varsayılanı kullanılır
GATEWAY_URL="http://localhost:8080"

# LLM API (OpenAI-compatible: OpenAI, llama.cpp, vLLM, LM Studio, Ollama proxy vb.)
LLM_API_URL="http://localhost:11434/v1/chat/completions"
LLM_API_KEY=""
LLM_MODEL="qwen3-coder:480b-cloud"

# Monitor
MONITOR_INTERVAL="60"
MONITOR_AUTO_FIX="true"

# MCP API Key (opsiyonel)
MCP_API_KEY=""
